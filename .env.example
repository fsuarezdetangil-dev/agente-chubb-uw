# Azure OpenAI
AZURE_OPENAI_API_KEY=           # API key de Azure OpenAI
AZURE_OPENAI_ENDPOINT=          # https://<tu-recurso>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=        # nombre del deployment (ej. gpt-4o)
AZURE_OPENAI_API_VERSION=       # ej. 2025-01-01-preview

# Phoenix Arize — observabilidad y tracing (sustituye a LangSmith)
PHOENIX_PROJECT_NAME=agente-chubb-uw
PHOENIX_API_KEY=                # JWT de app.phoenix.arize.com → Settings → API Keys
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<tu-space>/v1/traces  # slug del space visible en la URL del navegador
# LangSmith — SOLO para el harness de evaluación (run_langsmith_eval.py, upload_dataset.py)
# El tracing de observabilidad se hace con Phoenix (ver arriba).
# LANGCHAIN_TRACING_V2=true               # desactivado: tracing migrado a Phoenix
LANGSMITH_API_KEY=              # API key LangSmith EU (https://eu.api.smith.langchain.com)
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_PROJECT=agente-chubb-uw

# API
API_HOST=0.0.0.0
API_PORT=8000
